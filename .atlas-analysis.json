  "keyFeatures": [
    "Multi-tenant architecture with isolated Google Sheets databases per user",
    "Token-based authentication with email and WhatsApp verification",
    "Project and client management with status tracking and budget monitoring",
    "AI-powered chatbot management with WhatsApp integration via BuilderBot",
    "Real-time bot status monitoring and flow management",
    "Project-linked notes, links, and AI prompts for organized collaboration",
    "Interactive dashboard with analytics and upcoming deliveries",
    "Responsive design with mobile-friendly interface"
  ],
  "publicApiSurface": [
    "getClients(): Promise<Client[]>",
    "getClientByPhone(phone: string): Promise<Client | null>",
    "addClient(clientData: Omit<Client, 'id'>): Promise<Client>",
    "updateClient(clientData: Client): Promise<Client>",
    "deleteClient(clientId: string): Promise<{ success: boolean }>",
    "getProjects(): Promise<Project[]>",
    "addProject(projectData: Omit<Project, 'id' | 'clientName'>): Promise<Project>",
    "updateProject(projectData: Omit<Project, 'clientName'>): Promise<Project>",
    "deleteProject(projectId: string): Promise<{ success: boolean }>",
    "getBots(): Promise<Bot[]>",
    "addBot(botData): Promise<Bot>",
    "updateBot(botData: Bot): Promise<Bot>",
    "deleteBot(botId: string): Promise<{ success: boolean }>",
    "connectBot(botId: string): Promise<{ success: boolean }>",
    "disconnectBot(botId: string): Promise<{ success: boolean }>",
    "getBotQrCode(builderBotId: string): Promise<{ qr: string }>",
    "getBotFlows(builderBotId: string): Promise<Flow[]>",
    "getNotesByProjectId(projectId: string): Promise<Note[]>",
    "addNote(noteData): Promise<Note>",
    "updateNote(noteData: Note): Promise<Note>",
    "deleteNote(noteId: string): Promise<{ success: boolean }>",
    "getLinksByProjectId(projectId: string): Promise<Link[]>",
    "addLink(linkData): Promise<Link>",
    "updateLink(linkData: Link): Promise<Link>",
    "deleteLink(linkId: string): Promise<{ success: boolean }>",
    "getPromptsByProjectId(projectId: string): Promise<Prompt[]>",
    "addPrompt(promptData): Promise<Prompt>",
    "updatePrompt(promptData: Prompt): Promise<Prompt>",
    "deletePrompt(promptId: string): Promise<{ success: boolean }>"
  ]
}
